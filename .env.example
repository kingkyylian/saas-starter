# App
NEXT_PUBLIC_APP_NAME="My SaaS"
NEXT_PUBLIC_APP_DESCRIPTION="The fastest way to ship your SaaS."

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL="file:./dev.db"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# OAuth Providers (enable what you need)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Email magic link (Resend — resend.com, free tier: 100 emails/day)
RESEND_API_KEY=""
EMAIL_FROM="Your App <noreply@yourdomain.com>"

# AI Provider — Anthropic is wired up by default (claude-haiku-4-5)
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=""

# To switch to OpenAI: npm install openai, then edit src/lib/actions.ts
# OPENAI_API_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""
